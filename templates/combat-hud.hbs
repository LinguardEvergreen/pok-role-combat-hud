{{!-- PokéRole Combat HUD - Main Template --}}
<div class="poke-hud-wrapper" style="--hud-scale: {{scale}}">

  {{!-- Portrait Bar: Active Pokémon Info --}}
  {{#if pokemon}}
  <div class="poke-hud-portrait">
    <div class="portrait-header">
      <img class="pokemon-sprite" src="{{pokemon.img}}" alt="{{pokemon.name}}" width="64" height="64"/>
      <div class="pokemon-info">
        <div class="pokemon-name-row">
          <span class="pokemon-name">{{pokemon.name}}</span>
          {{#if pokemon.species}}
          <span class="pokemon-species">({{pokemon.species}})</span>
          {{/if}}
        </div>

        {{!-- Type Badges --}}
        <div class="type-badges">
          <span class="type-badge" style="background-color: {{pokemon.primaryTypeColor}}">
            {{pokemon.primaryType}}
          </span>
          {{#if pokemon.secondaryType}}
          <span class="type-badge" style="background-color: {{pokemon.secondaryTypeColor}}">
            {{pokemon.secondaryType}}
          </span>
          {{/if}}
        </div>
      </div>
    </div>

    {{!-- HP Bar --}}
    <div class="stat-bar hp-bar-container">
      <span class="bar-label">HP</span>
      <div class="bar-track">
        <div class="bar-fill {{pokemon.hpColor}}" style="width: {{pokemon.hpPercent}}%"></div>
      </div>
      <span class="bar-value">{{pokemon.hp.value}}/{{pokemon.hp.max}}</span>
    </div>

    {{!-- Will Bar --}}
    <div class="stat-bar will-bar-container">
      <span class="bar-label">Will</span>
      <div class="bar-track">
        <div class="bar-fill will-bar" style="width: {{pokemon.willPercent}}%"></div>
      </div>
      <span class="bar-value">{{pokemon.will.value}}/{{pokemon.will.max}}</span>
    </div>

    {{!-- Active Conditions --}}
    {{#if pokemon.conditions.length}}
    <div class="conditions-row">
      {{#each pokemon.conditions}}
      <span class="condition-badge" title="{{this.label}}">{{this.icon}}</span>
      {{/each}}
    </div>
    {{/if}}
  </div>
  {{/if}}

  {{!-- Sub-Panel Container --}}
  {{#if activePanel}}
  <div class="poke-hud-panel-wrapper">
    <button class="panel-close-btn" data-action="close-panel" title="Close">✕</button>
    <div class="poke-hud-panel panel-{{activePanel}}">

    {{!-- Battle Panel: Move Selection --}}
    {{#if (eq activePanel "battle")}}
    <div class="battle-panel-content">
      {{#if moves.length}}
      <div class="moves-grid">
        {{#each moves}}
        <button class="move-btn {{#unless this.isUsable}}disabled{{/unless}}"
                data-action="use-move"
                data-move-id="{{this.id}}"
                style="background-color: {{this.bgColor}}; color: {{this.textColor}}"
                {{#unless this.isUsable}}disabled{{/unless}}
                title="{{this.description}}">
          <span class="move-name">{{this.name}}</span>
          <div class="move-details">
            <span class="move-type-label">{{this.typeLabel}}</span>
            <span class="move-category">{{{this.categoryIcon}}}</span>
            {{#if this.power}}
            <span class="move-power">Pow: {{this.power}}</span>
            {{/if}}
            {{#if this.willCost}}
            <span class="move-will">Will: {{this.willCost}}</span>
            {{/if}}
          </div>
          <div class="move-meta">
            <span class="move-accuracy">{{this.accuracy}}</span>
            <span class="move-action-tag">{{this.actionTag}}</span>
          </div>
        </button>
        {{/each}}
      </div>
      {{else}}
      <p class="no-moves">{{localize "POKEHUD.Battle.NoMoves"}}</p>
      {{/if}}
    </div>
    {{/if}}

    {{!-- Pokémon Panel: Party --}}
    {{#if (eq activePanel "pokemon")}}
    <div class="pokemon-panel-content">
      {{#if party.length}}
      <div class="party-list">
        {{#each party}}
        <button class="party-member {{#if this.isActive}}active{{/if}} {{#if this.isFainted}}fainted{{/if}} {{#unless this.canSwitch}}disabled{{/unless}}"
                data-action="switch-pokemon"
                data-actor-id="{{this.id}}"
                {{#unless this.canSwitch}}disabled{{/unless}}>
          <img class="party-sprite" src="{{this.img}}" alt="{{this.name}}"/>
          <div class="party-info">
            <span class="party-name">{{this.name}}</span>
            <div class="party-hp-bar">
              <div class="bar-track small">
                <div class="bar-fill {{this.hpColor}}" style="width: {{this.hpPercent}}%"></div>
              </div>
              <span class="party-hp-text">{{this.hp.value}}/{{this.hp.max}}</span>
            </div>
            {{#if this.conditions.length}}
            <div class="party-conditions">
              {{#each this.conditions}}
              <span class="condition-mini">{{this.icon}}</span>
              {{/each}}
            </div>
            {{/if}}
          </div>
        </button>
        {{/each}}
      </div>
      {{else}}
      <p class="no-party">{{localize "POKEHUD.Pokemon.NoParty"}}</p>
      {{/if}}
    </div>
    {{/if}}

    {{!-- Bag Panel: Items --}}
    {{#if (eq activePanel "bag")}}
    <div class="bag-panel-content">
      {{#if bag.length}}
      {{#each bag}}
      <div class="bag-pocket">
        <h4 class="pocket-label">{{this.label}}</h4>
        <div class="pocket-items">
          {{#each this.items}}
          <button class="bag-item {{#if this.isEmpty}}empty{{/if}}"
                  data-action="use-item"
                  data-item-id="{{this.id}}"
                  {{#if this.isEmpty}}disabled{{/if}}>
            <img class="item-icon" src="{{this.img}}" alt="{{this.name}}" width="32" height="32"/>
            <div class="item-info">
              <span class="item-name">{{this.name}}</span>
              <span class="item-desc">{{this.description}}</span>
            </div>
            <span class="item-quantity">x{{this.quantity}}</span>
          </button>
          {{/each}}
        </div>
      </div>
      {{/each}}
      {{else}}
      <p class="no-items">{{localize "POKEHUD.Bag.NoItems"}}</p>
      {{/if}}
    </div>
    {{/if}}
    </div>
  </div>
  {{/if}}

  {{!-- Main Menu: 4 Action Buttons --}}
  <div class="poke-hud-menu {{#unless isMyTurn}}not-my-turn{{/unless}}">
    <button class="hud-btn battle-btn {{#if (eq activePanel 'battle')}}active{{/if}}"
            data-action="battle"
            {{#unless isMyTurn}}disabled{{/unless}}>
      <svg class="btn-icon" viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg">
        <circle cx="32" cy="32" r="28" fill="none" stroke="currentColor" stroke-width="3"/>
        <line x1="4" y1="32" x2="60" y2="32" stroke="currentColor" stroke-width="3"/>
        <circle cx="32" cy="32" r="10" fill="none" stroke="currentColor" stroke-width="3"/>
        <circle cx="32" cy="32" r="5" fill="currentColor"/>
        <line x1="14" y1="14" x2="24" y2="24" stroke="currentColor" stroke-width="2"/>
        <line x1="50" y1="14" x2="40" y2="24" stroke="currentColor" stroke-width="2"/>
        <line x1="14" y1="50" x2="24" y2="40" stroke="currentColor" stroke-width="2"/>
        <line x1="50" y1="50" x2="40" y2="40" stroke="currentColor" stroke-width="2"/>
      </svg>
      <span class="btn-label">{{localize "POKEHUD.Menu.Battle"}}</span>
    </button>

    <button class="hud-btn pokemon-btn {{#if (eq activePanel 'pokemon')}}active{{/if}}"
            data-action="pokemon"
            {{#unless isMyTurn}}disabled{{/unless}}>
      <svg class="btn-icon" viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg">
        <circle cx="32" cy="32" r="28" fill="none" stroke="currentColor" stroke-width="3"/>
        <line x1="4" y1="32" x2="60" y2="32" stroke="currentColor" stroke-width="3"/>
        <circle cx="32" cy="32" r="10" fill="none" stroke="currentColor" stroke-width="3"/>
        <circle cx="32" cy="32" r="5" fill="currentColor"/>
      </svg>
      <span class="btn-label">{{localize "POKEHUD.Menu.Pokemon"}}</span>
    </button>

    <button class="hud-btn bag-btn {{#if (eq activePanel 'bag')}}active{{/if}}"
            data-action="bag"
            {{#unless isMyTurn}}disabled{{/unless}}>
      <svg class="btn-icon" viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg">
        <rect x="12" y="20" width="40" height="36" rx="6" fill="none" stroke="currentColor" stroke-width="3"/>
        <path d="M22 20 Q22 10 32 10 Q42 10 42 20" fill="none" stroke="currentColor" stroke-width="3"/>
        <circle cx="32" cy="38" r="8" fill="none" stroke="currentColor" stroke-width="2"/>
        <line x1="24" y1="38" x2="40" y2="38" stroke="currentColor" stroke-width="2"/>
        <circle cx="32" cy="38" r="3" fill="currentColor"/>
      </svg>
      <span class="btn-label">{{localize "POKEHUD.Menu.Bag"}}</span>
    </button>

    <button class="hud-btn run-btn"
            data-action="run"
            {{#unless isMyTurn}}disabled{{/unless}}>
      <svg class="btn-icon" viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg">
        <circle cx="36" cy="12" r="6" fill="currentColor"/>
        <path d="M28 22 L38 22 L44 36 L38 36 L42 56 L32 56 L30 40 L26 56 L20 56 L24 36 L18 28 Z"
              fill="none" stroke="currentColor" stroke-width="2.5" stroke-linejoin="round"/>
        <line x1="46" y1="24" x2="54" y2="20" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
        <line x1="46" y1="28" x2="56" y2="28" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
        <line x1="46" y1="32" x2="54" y2="36" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
      </svg>
      <span class="btn-label">{{localize "POKEHUD.Menu.Run"}}</span>
    </button>
  </div>
</div>
